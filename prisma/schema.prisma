generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ftd {
  id                 Int      @id @default(autoincrement())
  providerSource     String
  eventType          String   @default("FTD")
  businessName       String
  registrationDate   DateTime
  customerName       String
  amount             Float
  rawCampaignName    String
  campaignBase       String
  campaignVariant    String?
  country            String
  finalReferenceName String?
  isSameDay          Boolean  @default(false)
  isDelayedFtd       Boolean  @default(false)
  rawMessage         String
  dedupeHash         String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([campaignBase, country])
  @@index([registrationDate])
  @@map("ftds")
}

model DailyLead {
  id           Int      @id @default(autoincrement())
  date         DateTime
  campaignBase String
  country      String
  leads        Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date, campaignBase, country])
  @@index([campaignBase, country])
  @@map("daily_leads")
}

model CampaignMetric {
  id                Int      @id @default(autoincrement())
  campaignBase      String
  country           String
  periodType        String
  periodStart       DateTime
  periodEnd         DateTime
  totalLeads        Int      @default(0)
  totalFtds         Int      @default(0)
  conversionRate    Float    @default(0)
  reached2Percent   Boolean  @default(false)
  topRank           Int?
  qualifiedForTop   Boolean  @default(false)
  triggerStatus     String   @default("do_not_fire")
  triggerReason     String?
  crmRecommendation String?
  updatedAt         DateTime @updatedAt

  @@unique([campaignBase, country, periodType, periodStart])
  @@index([campaignBase, country])
  @@map("campaign_metrics")
}

model Alert {
  id             Int      @id @default(autoincrement())
  campaignBase   String
  country        String
  alertType      String
  conversionRate Float
  triggeredAt    DateTime @default(now())
  status         String   @default("active")
  details        String?

  @@index([campaignBase, country])
  @@index([status])
  @@map("alerts")
}

model CrmAction {
  id             Int      @id @default(autoincrement())
  campaignBase   String
  country        String
  actionType     String
  reason         String?
  sourceMetricId Int?
  createdAt      DateTime @default(now())

  @@index([campaignBase, country])
  @@map("crm_actions")
}

model AppSetting {
  id                        Int      @id @default(autoincrement())
  weeklyThresholdPercent    Float    @default(2.0)
  monthlyThresholdPercent   Float    @default(2.0)
  weeklyMinLeadsForTop      Int      @default(20)
  monthlyMinLeadsForTop     Int      @default(40)
  weeklyMinLeadsForTrigger  Int      @default(20)
  monthlyMinLeadsForTrigger Int      @default(40)
  weekStartDay              Int      @default(1)
  weekEndDay                Int      @default(6)
  updatedAt                 DateTime @updatedAt

  @@map("app_settings")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("users")
}
