COMPANY_NAME="Vercel Inc."
SITE_NAME="Next.js Commerce"
SHOPIFY_REVALIDATION_SECRET=""
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
SHOPIFY_STORE_DOMAIN="[your-shopify-store-subdomain].myshopify.com"

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development default)
DATABASE_URL="file:./prisma/tracker.db"
# PostgreSQL + TimescaleDB (production)
# DATABASE_URL="postgres://user:pass@localhost:5432/voice_agent?sslmode=require"

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"

# ── Voice Orchestrator (Go microservice) ──────────────────────────────────────
# URL for the orchestrator's WebSocket server (used by Next.js to build ws:// URLs)
ORCHESTRATOR_WS_URL="ws://localhost:8080"
# Shared secret for HMAC-signing orchestrator → Next.js webhook events
ORCHESTRATOR_WEBHOOK_SECRET="change-me-in-production"
# API key required by the orchestrator to accept WebSocket upgrades
ORCHESTRATOR_API_KEY="change-me-in-production"
# Internal service-to-service token (Next.js → Next.js internal API calls)
INTERNAL_SERVICE_TOKEN="change-me-in-production"

# ── STT: Deepgram ─────────────────────────────────────────────────────────────
# https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=""

# ── LLM: OpenAI ──────────────────────────────────────────────────────────────
# https://platform.openai.com → API Keys
# Used for: GPT-4o (real-time inference) + GPT-4-turbo (post-call analysis)
OPENAI_API_KEY=""

# ── LLM: Groq (optional, lower latency alternative) ──────────────────────────
# https://console.groq.com → API Keys
GROQ_API_KEY=""

# ── TTS: ElevenLabs ───────────────────────────────────────────────────────────
# https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=""
# Voice ID from ElevenLabs voice library
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ── TTS: Cartesia (optional alternative) ─────────────────────────────────────
CARTESIA_API_KEY=""
CARTESIA_MODEL_ID="sonic-english"
CARTESIA_VOICE_ID=""

# ── Vector DB: Pinecone (RAG for sales objections) ───────────────────────────
# https://app.pinecone.io → API Keys
PINECONE_API_KEY=""
# Host URL for your index (found in Pinecone console)
PINECONE_INDEX_HOST="https://your-index-host.svc.pinecone.io"

# ── CRM Integrations ──────────────────────────────────────────────────────────
# HubSpot private app access token
HUBSPOT_ACCESS_TOKEN=""
# Salesforce connected-app credentials
SALESFORCE_INSTANCE_URL=""
SALESFORCE_ACCESS_TOKEN=""
# Generic webhook signing secret (for outbound CRM webhooks)
WEBHOOK_SIGNING_SECRET=""
