# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_PRICE_PRO=your-stripe-price-id-pro
STRIPE_PRICE_SCALE=your-stripe-price-id-scale

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Anthropic (for QA scoring)
ANTHROPIC_API_KEY=your-anthropic-api-key

# HubSpot (for OAuth CRM integration)
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret

# Cartesia (voice engine)
CARTESIA_API_KEY=your-cartesia-api-key

# Deepgram (transcription)
DEEPGRAM_API_KEY=your-deepgram-api-key

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
ADMIN_EMAIL=admin@your-domain.com

# Secrets — generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret
CRON_SECRET=your-cron-secret

# LiveKit — Core (required by webhook + worker)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# LiveKit SIP — Outbound Calling API
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=your-livekit-outbound-trunk-id

# AI Providers — Worker LLM + TTS + RAG embeddings
GROQ_API_KEY=gsk_your-groq-api-key
OPENAI_API_KEY=sk-your-openai-api-key
SUPPORT_TRANSFER_NUMBER=+18005551234

# Supabase Storage S3 — generate in Supabase dashboard → Storage → S3 Access Keys
# Required for automatic MP3 recording via LiveKit Egress
SUPABASE_S3_ACCESS_KEY=your-supabase-s3-access-key
SUPABASE_S3_SECRET_KEY=your-supabase-s3-secret-key

# LiveKit Edge Routing — optional regional overrides for < 50ms latency
# Leave blank to use LIVEKIT_URL for all regions (LiveKit Cloud handles this automatically)
LIVEKIT_URL_US_EAST=
LIVEKIT_URL_US_WEST=
LIVEKIT_URL_EU_WEST=
LIVEKIT_URL_AP_SE=

# Observability — optional (structured JSON logs work without these)
# Sentry: npm install @sentry/nextjs && uncomment Sentry.captureMessage in lib/tracing.ts
SENTRY_DSN=
# PostHog: npm install posthog-node
POSTHOG_API_KEY=
