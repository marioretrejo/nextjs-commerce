# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Retell AI
RETELL_API_KEY=your-retell-api-key
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_WEBHOOK_SECRET=your-elevenlabs-webhook-secret

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_PRICE_PRO=your-stripe-price-id-pro
STRIPE_PRICE_SCALE=your-stripe-price-id-scale

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Anthropic (for QA scoring)
ANTHROPIC_API_KEY=your-anthropic-api-key

# HubSpot (for OAuth CRM integration)
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret

# Cartesia (alternative voice engine)
CARTESIA_API_KEY=your-cartesia-api-key

# Deepgram (transcription)
DEEPGRAM_API_KEY=your-deepgram-api-key

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
ADMIN_EMAIL=admin@your-domain.com

# Secrets — generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret
CRON_SECRET=your-cron-secret
