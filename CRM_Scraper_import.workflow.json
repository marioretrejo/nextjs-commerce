    {
      "id": "n7",
      "name": "Parsear Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        360,
        50
      ],
      "parameters": {
        "jsCode": "const html = String($input.first().json);\nconst now  = new Date().toISOString();\n\n// Extraer datos de las filas Tabulator via regex sobre el HTML\nconst emailRx  = /tabulator-field=\"email\"[^>]*>\\s*<a[^>]*>([^<]+)<\\/a>/g;\nconst nameRx   = /tabulator-field=\"first_name\"[^>]*>([^<]+)</g;\nconst lastRx   = /tabulator-field=\"last_name\"[^>]*>([^<]+)</g;\nconst phoneRx  = /tabulator-field=\"phone\"[^>]*>\\s*<a[^>]*>([^<]+)<\\/a>/g;\nconst countryRx= /tabulator-field=\"country\"[^>]*>([^<]+)</g;\nconst brandRx  = /tabulator-field=\"brand\"[^>]*>([^<\\n]{1,40})/g;\nconst dateRx   = /tabulator-field=\"creation_date\"[^>]*>([^<]+)</g;\n\nconst extract = (rx, src) => { const r=[]; let m; while((m=rx.exec(src))!==null) r.push(m[1].trim()); return r; };\n\nconst emails   = extract(emailRx,   html);\nconst names    = extract(nameRx,    html);\nconst lastnames= extract(lastRx,    html);\nconst phones   = extract(phoneRx,   html);\nconst countries= extract(countryRx, html);\nconst brands   = extract(brandRx,   html);\nconst dates    = extract(dateRx,    html);\n\nif (!emails.length) return [{ json: { skip: true, reason: 'Sin leads en esta ejecución', timestamp: now } }];\n\nreturn emails.map((email, i) => ({\n  json: {\n    email,\n    nombre:    (names[i]    || '') + ' ' + (lastnames[i] || ''),\n    telefono:  phones[i]   || '',\n    pais:      countries[i]|| '',\n    brand:     brands[i]   || '',\n    fecha:     dates[i]    || '',\n    scrapeado: now,\n    fuente:    'tracker.machukllc.xyz'\n  }\n}));"
      }
    },
