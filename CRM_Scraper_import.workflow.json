      "name": "Extraer Cookie",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -120,
        50
      ],
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst raw  = resp.headers?.['set-cookie'] || [];\nconst list = Array.isArray(raw) ? raw : [raw];\nconst cookie = list.map(c => c.split(';')[0]).filter(Boolean).join('; ');\nif (!cookie) throw new Error('Login fallido - no se recibió cookie de sesión');\nreturn [{ json: { cookie } }];"
      }
    },
